{
  "name": "@bpi/design-system",
  "version": "1.0.0",
  "description": "BPI Design System — Web Components, CSS classes, and design tokens for multi-framework ERP projects",
  "type": "module",
  "main": "./dist/bpi.js",
  "module": "./dist/bpi.js",
  "types": "./types/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/bpi.js",
      "types": "./types/index.d.ts"
    },
    "./react": "./types/react.d.ts",
    "./vue": "./types/vue.d.ts",
    "./tokens": "./src/tokens/index.scss"
  },
  "files": [
    "dist",
    "types",
    "src/tokens"
  ],
  "scripts": {
    "build": "node scripts/build.js",
    "dev": "node scripts/build.js --watch"
  },
  "devDependencies": {
    "esbuild": "^0.20.0",
    "sass": "^1.77.0"
  },
  "keywords": [
    "design-system",
    "web-components",
    "bpi",
    "erp",
    "tokens"
  ],
  "license": "MIT"
}
